  <property name="styleSheet">
   <string notr="true">QDialog, QWidget {
    background-color: #000000; /* negro */
}


/* QLabel */
QLabel {
    color: #FFD700;
    font-weight: bold;
    font-size: 26pt;
}


/* Botones gaming */
QPushButton {
    background-color: #8B0000;
    color: #FFD700;
    border: 2px solid #FFD700;
    border-radius: 10px;
    padding: 8px 16px;
    font-weight: bold;
}
/* QLineEdit estilo gaming */
QLineEdit {
    background-color: #1a0000; /* negro con tono rojizo */
    color: #FFD700; /* texto dorado */
    border: 2px solid #8B0000; /* rojo oscuro */
    border-radius: 8px;
    padding: 6px;
    selection-background-color: #8B0000; /* cuando seleccionas texto */
    selection-color: #FFD700;
}


/* Cuando el usuario hace clic */
QLineEdit:focus {
    border: 2px solid #FFD700; /* borde dorado brillante */
    background-color: #260000;
}


/* Hover */
QLineEdit:hover {
    border: 2px solid #B22222;
}


/* Placeholder (texto guía) */
QLineEdit::placeholder {
    color: #aa6666; /* rojizo tenue */
}
QPushButton:hover {
    background-color: #B22222;
}


QPushButton:pressed {
    background-color: #550000;
}</string>
